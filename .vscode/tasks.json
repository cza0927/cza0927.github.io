{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll Live Preview",
      "type": "shell",
      "command": "./run_server.sh",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": [
          {
            "regexp": "^(.*)$",
            "file": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[preview\\] Starting Jekyll live server",
          "endsPattern": "Server running|Auto-regeneration: enabled"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "clear": false
      }
    }
  ]
}
